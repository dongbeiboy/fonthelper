<Page
    x:Class="TOfont.WinUI.Pages.ExtractionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Column="0" Padding="12">
            <StackPanel Spacing="8">

                <ComboBox x:Name="ModeSwitch" Header="模式" SelectedIndex="0"
                    SelectionChanged="OnModeChanged" />

                <StackPanel x:Name="TextPanel" Spacing="6">
                    <TextBox x:Name="InputTextBox" Header="输入文字"
                        Text="你好" AcceptsReturn="True" MaxHeight="80" />

                    <ComboBox x:Name="FontCombo" Header="字体"
                        SelectedIndex="0" />

                    <controls:NumberBox x:Name="SizeBox" Header="字号(px)"
                        Value="16" Minimum="4" Maximum="256" SpinButtonPlacementMode="Inline"
                        ValueChanged="OnSizeChanged" />
                    <TextBlock x:Name="SizeWarning" Text="字号过小，可能影响易读性"
                        Foreground="#0078D4" FontSize="11" Margin="0,-2,0,0" Visibility="Collapsed" />

                    <CheckBox x:Name="BoldChk" Content="粗体" />
                    <CheckBox x:Name="ItalicChk" Content="斜体" />
                </StackPanel>

                <StackPanel x:Name="ImagePanel" Spacing="6" Visibility="Collapsed">
                    <TextBox x:Name="ImagePathBox" Header="图片路径" PlaceholderText="选择图片文件..." />
                    <Button Content="浏览..." Click="OnBrowseImage" />
                    <controls:NumberBox x:Name="ThresholdBox" Header="二值化阈值"
                        Value="128" Minimum="0" Maximum="255" SpinButtonPlacementMode="Inline" />
                    <TextBlock Text="裁剪 (可选)" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <controls:NumberBox x:Name="CropXBox" Header="X" Value="0" Minimum="0" Width="120" SpinButtonPlacementMode="Inline" />
                        <controls:NumberBox x:Name="CropYBox" Header="Y" Value="0" Minimum="0" Width="120" SpinButtonPlacementMode="Inline" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <controls:NumberBox x:Name="CropWBox" Header="宽" PlaceholderText="原始" Width="120" SpinButtonPlacementMode="Inline" />
                        <controls:NumberBox x:Name="CropHBox" Header="高" PlaceholderText="原始" Width="120" SpinButtonPlacementMode="Inline" />
                    </StackPanel>
                    <TextBlock Text="缩放 (可选)" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <controls:NumberBox x:Name="ScaleWBox" Header="目标宽" PlaceholderText="原始" Width="120" SpinButtonPlacementMode="Inline" />
                        <controls:NumberBox x:Name="ScaleHBox" Header="目标高" PlaceholderText="原始" Width="120" SpinButtonPlacementMode="Inline" />
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="FontLibPanel" Spacing="6" Visibility="Collapsed">
                    <TextBox x:Name="PtlPathBox" Header="字符列表 (PTL)" PlaceholderText="选择 PTL 文件..." />
                    <Button Content="浏览..." Click="OnBrowsePtl" />
                    <TextBlock x:Name="PtlCharCount" Text="未加载" FontSize="11"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBox x:Name="OutputPathBox" Header="输出文件" PlaceholderText="保存为 .h 文件..." />
                    <Button Content="浏览..." Click="OnBrowseOutput" />
                </StackPanel>

                <StackPanel x:Name="FontImportPanel" Spacing="6" Visibility="Collapsed">
                    <TextBox x:Name="FontFileBox" Header="字库文件" PlaceholderText="选择二进制字库文件..." />
                    <Button Content="浏览..." Click="OnBrowseFontFile" />
                    <controls:NumberBox x:Name="FontWidthBox" Header="字符宽度" Value="16" Minimum="4" Maximum="256" SpinButtonPlacementMode="Inline" />
                    <controls:NumberBox x:Name="FontHeightBox" Header="字符高度" Value="16" Minimum="4" Maximum="256" SpinButtonPlacementMode="Inline" />
                    <controls:NumberBox x:Name="FileOffsetBox" Header="起始偏移(字节)" Value="0" Minimum="0" Maximum="1048576" SpinButtonPlacementMode="Inline" />
                </StackPanel>

                <TextBlock Text="取模设置" FontWeight="SemiBold" Margin="0,8,0,0"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="11" />
                <HyperlinkButton Content="前往设置页面调整扫描模式等选项"
                    Click="OnGoSettings" />

                <Button x:Name="ExtractBtn" Content="开始取模" Click="OnExtract"
                    Style="{StaticResource AccentButtonStyle}" Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefault}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8" Padding="12">
                <TextBlock Text="预览" VerticalAlignment="Center" FontWeight="SemiBold" />
                <Button Content="-" Width="36" Click="OnZoomOut" />
                <Button Content="+" Width="36" Click="OnZoomIn" />
                <TextBlock x:Name="ZoomLabel" Text="8px" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="画布预设" VerticalAlignment="Center" FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ComboBox x:Name="CanvasPreset" SelectedIndex="0"
                        SelectionChanged="OnCanvasPresetChanged">
                        <ComboBoxItem>自由</ComboBoxItem>
                        <ComboBoxItem>128×64</ComboBoxItem>
                        <ComboBoxItem>128×32</ComboBoxItem>
                        <ComboBoxItem>128×128</ComboBoxItem>
                        <ComboBoxItem>160×128</ComboBoxItem>
                        <ComboBoxItem>240×240</ComboBoxItem>
                        <ComboBoxItem>320×240</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <ScrollViewer x:Name="PreviewScroll" Grid.Row="1"
                HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image x:Name="PreviewImage" Stretch="None" />
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="2" Padding="12,12,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="输出代码" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Content="复制" Click="OnCopyOutput" />
                <Button x:Name="SaveBtn" Content="保存" Click="OnSaveOutput" Visibility="Collapsed" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" Margin="0,6,0,0">
                <TextBox x:Name="OutputBox" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                    AcceptsReturn="True" TextWrapping="Wrap" />
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                <TextBlock x:Name="StatusText" Text="就绪" FontSize="11"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Grid.ColumnSpan="3"
            Background="{ThemeResource CardBackgroundFillColorSecondary}"
            Padding="8,4" BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource DividerStrokeColorDefault}">
            <TextBlock x:Name="StatusBar" Text="就绪 | 文字模式"
                FontSize="11" VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </Border>

    </Grid>
</Page>
